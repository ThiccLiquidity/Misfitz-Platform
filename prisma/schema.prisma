// Chia NFT Collector Platform — Prisma schema
// Mirrors ARCHITECTURE.md §3. SQLite for local dev convenience; swap `provider`/`url`
// to Postgres for production (see ARCHITECTURE.md §1) — no model changes required.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  wallets        Wallet[]
  profile        Profile?
  watchlist      UserWatchlist[]
  follows        UserCollectionFollow[]
  badges         UserBadge[]
}

model Wallet {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  address    String
  label      String?
  // Which wallet produced the proof: "sage" | "goby" | "manual" | other. Informational only —
  // server-side verification (ARCHITECTURE.md §6) is wallet-agnostic.
  walletType String?
  // null = claimed but unverified (Phase 1 paste). Set once a challenge signature is verified
  // server-side (Phase 2). Verified wallets unlock profile badges + artist airdrop eligibility.
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  challenges WalletChallenge[]

  // A given address can only be linked once per user (re-linking updates the same row).
  @@unique([userId, address])
  @@index([userId])
}

// Single-use, short-TTL nonce backing the Phase 2 challenge-response flow (ARCHITECTURE.md §6).
// The user signs a message containing `nonce` with their Chia wallet; the backend verifies the
// signature server-side, then marks the matching Wallet.verifiedAt. consumedAt makes each
// challenge one-shot, which (together with expiresAt) defeats replay.
model WalletChallenge {
  id         String    @id @default(cuid())
  walletId   String
  wallet     Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
  nonce      String    @unique
  // The exact human-readable string the wallet is asked to sign (includes nonce, address, domain,
  // and issued-at). Stored verbatim so verification reconstructs the identical signed payload.
  message    String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([walletId])
}

model Profile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  username      String   @unique
  avatarUrl     String?
  bio           String?
  // Highest level ever reached — permanent, never lowered. See ARCHITECTURE.md §3 note.
  collectorLevel Int     @default(1)
  createdAt     DateTime @default(now())
}

// A collection is a plugin registration mirrored into the database (ARCHITECTURE.md §8).
model Collection {
  id                String   @id @default(cuid())
  slug              String   @unique
  name              String
  description       String?
  bannerUrl         String?
  iconUrl           String?
  chainCollectionId String? // on-chain / MintGarden collection id; null until live integration
  dataSourceKey     String   @default("mock") // "mock" | "mintgarden" | future adapters
  themeConfig       String // JSON: accent color, logo, card chrome tweaks — see src/lib/theme
  traitSchema       String? // JSON: optional hint for how to render this collection's traits
  // True series size (e.g. 10000), independent of how many NFTs are currently loaded into
  // `nfts` below. Rarity tiers (src/lib/rarity) are computed as rarityRank/totalSupply, so this
  // must stay the real collection size even while we're importing a small batch at a time.
  totalSupply       Int      @default(0)
  // JSON: optional override of rarity tier percentage cutoffs (src/lib/rarity/tiers.ts). Null
  // means "use the platform defaults" — most collections never need to set this.
  tierConfig        String?
  createdAt         DateTime @default(now())

  nfts    Nft[]
  follows UserCollectionFollow[]
  syncLogs SyncLog[]
}

model Nft {
  id                  String   @id @default(cuid())
  collectionId        String
  collection          Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  launcherId          String   @unique // on-chain coin id (mock data uses a stable fake id)
  name                String
  imageUrl            String
  metadata            String // JSON — collection-specific, generic columns below cover the common case
  traits              String // JSON — array of { trait_type, value }, rendered generically by TraitsList
  rarityRank          Int?
  currentOwnerAddress String?
  lastSyncedAt        DateTime?

  fairValueEstimate FairValueEstimate?
  watchlistedBy     UserWatchlist[]

  @@index([collectionId])
}

// Explainable fair value — stored as components, never just a final number (product requirement).
model FairValueEstimate {
  id                     String   @id @default(cuid())
  nftId                  String   @unique
  nft                    Nft      @relation(fields: [nftId], references: [id], onDelete: Cascade)
  floorValue             Float
  rarityPremium          Float
  traitPremium           Float
  historicalSalesPremium Float? // future component, nullable until sales history exists
  demandPremium          Float? // future component
  rewardValue            Float? // future component (CAT token rewards)
  totalEstimate          Float
  estimatedAt            DateTime @default(now())
}

model UserWatchlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nftId     String
  nft       Nft      @relation(fields: [nftId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, nftId])
}

model UserCollectionFollow {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([userId, collectionId])
}

// Static badge catalog — defining a new badge is a registration, not a migration.
model Badge {
  id          String @id @default(cuid())
  key         String @unique
  name        String
  description String
  iconUrl     String?

  earnedBy UserBadge[]
}

// Append-only. Never deleted or recomputed away — badge permanence is enforced by only ever inserting.
model UserBadge {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId      String
  badge        Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt     DateTime @default(now())
  earnedReason String?

  @@unique([userId, badgeId])
}

model SyncLog {
  id           String    @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  source       String
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  status       String // "running" | "success" | "error"
  errorMessage String?

  @@index([collectionId])
}
