# SQLite for local dev (swap to a Postgres connection string for production — see ARCHITECTURE.md §1)
DATABASE_URL="file:./dev.db"

# Auth.js — generate with: npx auth secret
NEXTAUTH_SECRET="replace-with-a-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ── Wallet verification (ARCHITECTURE.md §6 / WALLET_SETUP.md) ──────────────────
# Which server-side verifier checks signatures. "mock" (default, safe for dev) accepts only
# simulated signatures; "chia-bls" is the REAL verifier and must NOT be enabled until it has been
# implemented, tested against a real signature, and security-reviewed (see WALLET_SETUP.md).
WALLET_VERIFIER="mock"

# Sage (WalletConnect) connect. Get a free project id at https://dashboard.reown.com (formerly
# WalletConnect Cloud). Leave blank to keep Sage connect disabled and use manual linking only.
NEXT_PUBLIC_WC_PROJECT_ID=""
# "chia:mainnet" or "chia:testnet" — must match what the user's Sage wallet is on.
NEXT_PUBLIC_WC_CHAIN="chia:mainnet"

# ── Comparable-sales valuation (src/lib/valuation/comps.ts) ─────────────────────
# When "true", live collection values blend in REAL sales-derived prices (rank curve + trait
# premiums), weighted by confidence, with the floor+premium estimate as the fallback. Default OFF
# = exactly the prior behaviour. Safe to flip on/off; the model is built/cached in the background
# and never blocks a page load. After flipping on, values upgrade within ~10 min (cache warm-up).
# Default is ON. Uncomment to DISABLE.
# VALUATION_COMPS_ENABLED="false"
