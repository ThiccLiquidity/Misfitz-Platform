# Traitfolio — environment variables (set these in your host's dashboard, e.g. Vercel > Settings > Environment Variables)

# REQUIRED in production. Your real origin — used for Open Graph image URLs, robots.txt, sitemap.xml.
# No trailing slash.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# OPTIONAL. Comps (comparable-sales) valuation blend. On by default in code; set to "0" only to disable.
# VALUATION_COMPS_ENABLED=1

# OPTIONAL. Adaptive evidence-recency half-life (your locked model). On by default; set "0" to fall back
# to the fixed parabola.
# TRAITFOLIO_ADAPTIVE_HALFLIFE=1

# OPTIONAL. Override the MintGarden API base (has a sensible default).
# MINTGARDEN_API_BASE=https://api.mintgarden.io
