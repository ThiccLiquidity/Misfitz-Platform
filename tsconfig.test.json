{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": ".test-build",
    "rootDir": ".",
    "baseUrl": ".",
    "incremental": false,
    "jsx": "react-jsx",
    "isolatedModules": false,
    "plugins": []
  },
  "include": ["tests/**/*.ts", "src/**/*.ts"],
  "exclude": ["node_modules", ".test-build", ".next"]
}
